# Copy this file to .env and fill in real values. Do not commit .env.

# --- Phase 1: 2Captcha (required for unattended Karnataka HC lookup) ---
# Sign up at https://2captcha.com, fund a small prepaid balance, paste API key here.
TWOCAPTCHA_API_KEY=

# --- Phase 2: SMTP for outgoing notification email ---
# Leave blank for Phase 1. Filled in when email delivery is wired up.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Local proxy port (default 4005) ---
PORT=4005
